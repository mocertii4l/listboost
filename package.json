{
  "name": "listboost-for-vinted",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "npm run build:css",
    "build:css": "tailwindcss -c tailwind.config.cjs -i ./src/styles-linear.css -o ./public/styles-linear.css --minify",
    "check": "node --check server.js && node --check public/app.js && node --check public/site.js && node --check public/auth-utils.js && npm test",
    "fetch:homepage-images": "node scripts/fetch-homepage-images.js",
    "test": "node --test tests/*.test.js",
    "dev": "node server.js",
    "start": "node server.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.0",
    "better-sqlite3": "^12.9.0",
    "dotenv": "^17.2.3",
