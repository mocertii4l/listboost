PORT=3000
APP_URL=http://localhost:3000
NODE_ENV=development
FREE_CREDITS=3
CREDIT_PACK_SIZE=50
CREDIT_PACK_PRICE_PENCE=700
# Source of truth for public credit packs and Stripe checkout pack selection.
CREDIT_PACKS_JSON=[{"id":"starter","name":"Starter","credits":50,"pricePence":700,"label":"Flexible top-up","description":"A one-time pack for occasional listing sessions."},{"id":"seller","name":"Seller","credits":150,"pricePence":1800,"label":"Popular top-up","description":"A flexible top-up for regular Vinted sellers who are not ready to subscribe.","featured":true},{"id":"reseller","name":"Reseller","credits":400,"pricePence":4500,"label":"Bulk top-up","description":"A larger one-time pack for reseller batches."}]

# Where SQLite + usage.json live. On Railway, point this at the mounted volume
# (e.g. DATA_DIR=/data) so listings and accounts survive redeploys.
DATA_DIR=

# Email verification gate. Set to "false" only for local hacking.
REQUIRE_EMAIL_VERIFICATION=true
RESEND_API_KEY=
# Local tests can set this to true to avoid sending password reset email.
RESEND_MOCK_EMAIL=false
EMAIL_FROM=ListBoost <support@listboost.uk>
SUPPORT_EMAIL=support@listboost.uk

# Social sign-in. Create OAuth apps in Google Cloud Console and Microsoft Entra,
# then add these callback URLs:
#   http://localhost:3000/auth/google/callback
#   http://localhost:3000/auth/microsoft/callback
# Preview callbacks for Railway:
#   https://listboost-preview-production.up.railway.app/auth/google/callback
#   https://listboost-preview-production.up.railway.app/auth/microsoft/callback
# Production callbacks should use your final APP_URL domain, e.g.
#   https://www.listboost.uk/auth/google/callback
#   https://www.listboost.uk/auth/microsoft/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
# Use "common" for personal + work Microsoft accounts, or your tenant ID.
MICROSOFT_TENANT_ID=common

# Pick one provider. OpenAI is the default if both keys exist.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
# Optional override for vision calls. Falls back to OPENAI_MODEL if unset.
OPENAI_VISION_MODEL=

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest
ANTHROPIC_VISION_MODEL=

# Stripe Checkout for credit packs. Test mode keys for local dev.
STRIPE_SECRET_KEY=
# REQUIRED in production. In Stripe Dashboard add endpoint:
# https://YOUR_DOMAIN/api/stripe-webhook
# Events: checkout.session.completed, invoice.paid,
# customer.subscription.updated, customer.subscription.deleted
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_SELLER_MONTHLY=
STRIPE_PRICE_RESELLER_MONTHLY=
# Optional source of truth for monthly plans. Omit this to use the built-in defaults.
SUBSCRIPTION_PLANS_JSON=[{"id":"starter","name":"Starter","monthlyLimit":20,"pricePence":699,"label":"Monthly starter","description":"For casual sellers who need the core notes-to-listing generator.","priceEnv":"STRIPE_PRICE_STARTER_MONTHLY"},{"id":"seller","name":"Seller","monthlyLimit":75,"pricePence":1499,"label":"Best value","description":"For regular sellers who want photos, buyer replies, price guidance and listing scores.","featured":true,"priceEnv":"STRIPE_PRICE_SELLER_MONTHLY"},{"id":"reseller","name":"Elite","monthlyLimit":250,"pricePence":2999,"label":"Elite tools","description":"For serious resellers running larger volumes with priority support.","priceEnv":"STRIPE_PRICE_RESELLER_MONTHLY"}]

# Admin page (/admin) HTTP Basic Auth. Leave both blank to disable the page.
ADMIN_EMAIL=
ADMIN_PASSWORD=
