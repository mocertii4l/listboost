PORT=3000
APP_URL=http://localhost:3000
NODE_ENV=development
FREE_CREDITS=5
CREDIT_PACK_SIZE=50
CREDIT_PACK_PRICE_PENCE=500
# Source of truth for public credit packs and Stripe checkout pack selection.
CREDIT_PACKS_JSON=[{"id":"starter","name":"Starter","credits":50,"pricePence":500,"label":"Try it","description":"A practical first pack for a wardrobe clear-out or first seller test."},{"id":"seller","name":"Seller","credits":150,"pricePence":1200,"label":"Best value","description":"The best value pack for regular Vinted sellers listing every week.","featured":true},{"id":"reseller","name":"Reseller","credits":400,"pricePence":2500,"label":"Power seller","description":"For bulk listing sessions, serious resellers and repeat sellers."}]

# Where SQLite + usage.json live. On Railway, point this at the mounted volume
# (e.g. DATA_DIR=/data) so listings and accounts survive redeploys.
DATA_DIR=

# Email verification gate. Set to "false" only for local hacking.
REQUIRE_EMAIL_VERIFICATION=true
RESEND_API_KEY=
EMAIL_FROM=ListBoost <onboarding@resend.dev>
SUPPORT_EMAIL=hello@listboost.app

# Pick one provider. OpenAI is the default if both keys exist.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
# Optional override for vision calls. Falls back to OPENAI_MODEL if unset.
OPENAI_VISION_MODEL=

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest
ANTHROPIC_VISION_MODEL=

# Stripe Checkout for credit packs. Test mode keys for local dev.
STRIPE_SECRET_KEY=
# REQUIRED in production. In Stripe Dashboard add endpoint:
# https://YOUR_DOMAIN/api/stripe-webhook
# Events: checkout.session.completed
STRIPE_WEBHOOK_SECRET=

# Admin page (/admin) HTTP Basic Auth. Leave both blank to disable the page.
ADMIN_EMAIL=
ADMIN_PASSWORD=
